# OBRIGATORIAS AGORA - Supabase publico e autenticacao.
# Estas duas variaveis chegam ao navegador. Use apenas a URL e a anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OBRIGATORIA AGORA - identifica o tenant white label desta implantacao.
NEXT_PUBLIC_TENANT_SLUG=

# SOMENTE SERVIDOR - necessario apenas para operacoes administrativas do
# checkout Asaas. Nunca prefixe com NEXT_PUBLIC_ e nunca exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# PAGAMENTO PAUSADO - mantenha vazias enquanto o checkout Asaas nao estiver
# operacionalmente aprovado. Configure apenas no ambiente seguro da Vercel.
ASAAS_API_KEY=
ASAAS_ENV=production
ASAAS_BASE_URL=https://api.asaas.com/v3

# FUTURO - sera usado quando o webhook Asaas for implementado.
ASAAS_WEBHOOK_TOKEN=
